# NeuroCortex frontend environment variables

# FastAPI backend base URL (no trailing slash)
VITE_API_URL=http://localhost:8000

# Set to "true" to skip API auth and use local-only registration/login
# VITE_USE_LOCAL_STORE=false

# Optional informational mirror of backend STUDY_MODE for local UI checks.
# Researcher banners are driven by GET /v1/research/study-config.
# VITE_STUDY_MODE=development
