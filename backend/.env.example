# Copy to .env and fill in values before running the API.
# NEVER commit .env to version control.

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://neurocortex:neurocortex@localhost:5432/neurocortex

# JWT — use a long random secret in production (e.g. openssl rand -hex 32)
JWT_SECRET=neurocortex-dev-secret-7f93a8d2-long-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
ENVIRONMENT=development
API_PREFIX=/v1

# Study mode: development | pilot | production
STUDY_MODE=development

# Optional overrides. When omitted:
# - SHOW_TEST_DATA defaults to true in development, false otherwise
# - ALLOW_PARTICIPANT_PREDICTIONS defaults to false
# SHOW_TEST_DATA=true
# ALLOW_PARTICIPANT_PREDICTIONS=false

# Synthetic integration-test identifiers to hide in pilot/production
BLOCK_SYNTHETIC_PREFIXES=MLSEED,MLPRED,MLSHAP
SYNTHETIC_DATASET_PREFIX=phase-2

# Consent and protocol
# REQUIRE_CONSENT_FOR_SESSIONS defaults to false in development, true in pilot/production
# REQUIRE_CONSENT_FOR_SESSIONS=false
ACTIVE_STUDY_PROTOCOL_VERSION=2026-pilot-v1
ALLOW_RESEARCHER_CONSENT_OVERRIDE=false
